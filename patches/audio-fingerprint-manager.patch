index 0000000000..6ec4dc5265
--- /dev/null
+++ b/dom/base/AudioFingerprintManager.cpp
@@ -0,0 +1,106 @@
+#include "AudioFingerprintManager.h"
+#include "nsTHashMap.h"  // Must come before RoverfoxStorageManager.h for template defs
+#include "nsHashKeys.h"  // For nsStringHashKey
+#include "RoverfoxStorageManager.h"
+#include "MaskConfig.hpp"
+#include "nsGlobalWindowInner.h"
+#include "xpcpublic.h"
+#include "mozilla/dom/BrowsingContext.h"
+#include <algorithm>
+
+namespace mozilla {
+namespace dom {
+
+/* static */ nsString
+AudioFingerprintManager::DisabledKeyForUserContext(uint32_t userContextId) {
+  nsString key;
+  key.AppendPrintf("audio_disabled_%u", userContextId);
+  return key;
+}
+
+/* static */ void
+AudioFingerprintManager::DisableFunction(uint32_t userContextId) {
+  nsString key = DisabledKeyForUserContext(userContextId);
+  RoverfoxStorageManager::PutBool(key, true);
+}
+
+/* static */ void
+AudioFingerprintManager::SetSeed(uint32_t aUserContextId, uint32_t aSeed) {
+  nsString key;
+  key.AppendPrintf("audioFingerprintSeed_%u", aUserContextId);
+  RoverfoxStorageManager::PutUint(key, aSeed);
+  DisableFunction(aUserContextId);
+}
+
+/* static */ uint32_t
+AudioFingerprintManager::GetSeed(uint32_t aUserContextId) {
+  nsString key;
+  key.AppendPrintf("audioFingerprintSeed_%u", aUserContextId);
+  uint32_t seed = 0;
+  if (RoverfoxStorageManager::GetUint(key, seed) && seed != 0) {
+    return seed;
+  }
+  // Fallback to CAMOU_CONFIG for Workers in separate processes
+  if (auto val = MaskConfig::GetUint32("audio:seed")) {
+    return val.value();
+  }
+  return 0;
+}
+
+/* static */ void
+AudioFingerprintManager::ApplyTransformation(float* data, uint32_t length, uint32_t seed) {
+  if (seed == 0 || length == 0 || !data) {
+    return;
+  }
+  // LCG for deterministic transformation - same seed always produces same result
+  // Uses 0.8% variance (range [0.996, 1.004]) with non-linear polynomial component
+  // This is more robust than Brave's 0.1-0.2% variance which was bypassed
+  uint32_t state = seed;
+  for (uint32_t i = 0; i < length; ++i) {
+    state = (state * 1664525u + 1013904223u);
+    float normalized = static_cast<float>(state) / 4294967295.0f;
+    // Linear base: 0.8% variance
+    float base = 0.996f + normalized * 0.008f;
+    // Non-linear polynomial adjustment - makes reverse-engineering harder
+    float adjustment = (normalized * normalized - 0.5f) * 0.002f;
+    float multiplier = base + adjustment;
+    data[i] *= multiplier;
+  }
+}
+
+/* static */ void
+AudioFingerprintManager::ApplyTransformationToBytes(uint8_t* data, uint32_t length, uint32_t seed) {
+  if (seed == 0 || length == 0 || !data) {
+    return;
+  }
+  // For byte data, apply small integer adjustments based on seed
+  uint32_t state = seed;
+  for (uint32_t i = 0; i < length; ++i) {
+    state = (state * 1664525u + 1013904223u);
+    // Small adjustment: -1, 0, or +1
+    int32_t adjustment = static_cast<int32_t>(state % 3) - 1;
+    int32_t newValue = static_cast<int32_t>(data[i]) + adjustment;
+    // Clamp to valid byte range
+    data[i] = static_cast<uint8_t>(std::max(0, std::min(255, newValue)));
+  }
+}
+
+/* static */ bool
+AudioFingerprintManager::IsFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj) {
+  nsGlobalWindowInner* win = xpc::WindowOrNull(aObj);
+  if (!win) {
+    return false;
+  }
+
+  uint32_t userContextId = 0;
+  if (BrowsingContext* bc = win->GetBrowsingContext()) {
+    userContextId = bc->OriginAttributesRef().mUserContextId;
+  }
+
+  bool disabled = false;
+  RoverfoxStorageManager::GetBool(DisabledKeyForUserContext(userContextId), disabled);
+  return !disabled;
+}
+
+}  // namespace dom
+}  // namespace mozilla
