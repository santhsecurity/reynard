+
+namespace mozilla {
+namespace dom {
+
+class AudioFingerprintManager {
+ public:
+  static void SetSeed(uint32_t aUserContextId, uint32_t aSeed);
+  static uint32_t GetSeed(uint32_t aUserContextId);
+
+  static void ApplyTransformation(float* data, uint32_t length, uint32_t seed);
+  static void ApplyTransformationToBytes(uint8_t* data, uint32_t length, uint32_t seed);
+
+  static void DisableFunction(uint32_t userContextId);
+  static bool IsFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj);
+
+ private:
+  static nsString DisabledKeyForUserContext(uint32_t userContextId);
+};
+
+}  // namespace dom
+}  // namespace mozilla
+
+#endif  // mozilla_dom_AudioFingerprintManager_h
